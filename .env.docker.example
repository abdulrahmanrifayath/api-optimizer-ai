# Production Docker Environment Variables Configuration
DATABASE_URL=mysql+pymysql://root:root@db:3306/api_optimizer_db
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=api_optimizer_db
MYSQL_USER=api_user
MYSQL_PASSWORD=api_password

JWT_SECRET=change_this_to_a_secure_random_256_bit_secret_key_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1
